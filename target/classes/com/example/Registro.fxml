<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.RegistroController">
   <children>
      <Label text="Crear Cuenta">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </Label>
      
      <Label text="Regístrate para empezar a guardar tus prompts" textFill="#666666" />

      <TextField fx:id="usuario_registro" maxWidth="250.0" promptText="Elige un nombre de usuario" style="-fx-background-radius: 5; -fx-padding: 8;" />

      <PasswordField fx:id="contraseña_registro" maxWidth="250.0" promptText="Crea una contraseña" style="-fx-background-radius: 5; -fx-padding: 8;" />
      
      <PasswordField fx:id="contraseña_repetir" maxWidth="250.0" promptText="Repite la contraseña" style="-fx-background-radius: 5; -fx-padding: 8;" />

      <Button fx:id="aceptar_registro" mnemonicParsing="false" onAction="#validar_registro" prefWidth="250.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;" text="REGISTRARSE" />
      
      <Label fx:id="text_error_registro" textFill="#e53935">
         <font>
            <Font size="13.0" />
         </font>
      </Label>
   </children>
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
</VBox>