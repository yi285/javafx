<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.RegistroController">
    <children>
        <Label text="¡Bienvenido al Gestor de Prompts!">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        
        <Label text="Aquí podrás gestionar tus prompts próximamente." />

        <Button fx:id="secondaryButton" text="Cerrar Sesión" onAction="#switchToPrimary" 
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-cursor: hand;" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>