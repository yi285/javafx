<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.LoginController">
   <children>
      <Label text="Gestor de Prompts">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      
      <Label text="Inicia sesión para continuar" textFill="#666666" />

      <TextField fx:id="usuario" maxWidth="250.0" promptText="Nombre de usuario" style="-fx-background-radius: 5; -fx-padding: 8;" />

      <PasswordField fx:id="contrasena" maxWidth="250.0" promptText="Contraseña" style="-fx-background-radius: 5; -fx-padding: 8;" />

      <Button fx:id="acceptar_log_in" mnemonicParsing="false" onAction="#validar_log_in" prefWidth="250.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;" text="ENTRAR" />
      
      <Label fx:id="text_error_log_in" textFill="#e53935" />
   </children>
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
</VBox>
